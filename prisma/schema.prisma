generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Conversation {
  id                String   @id @default(cuid())
  title             String   @default("New conversation")
  instructions      String?
  inheritFromConvId String?
  createdAt         DateTime @default(now())
  branches          Branch[]
}

model GlobalSetting {
  key   String @id
  value String @default("")
}

model Branch {
  id              String   @id @default(cuid())
  conversationId  String
  name            String   @default("main")
  forkedFromMsgId String?
  headMessageId   String?
  createdAt       DateTime @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages        Message[]
  stashes         Stash[]
}

model Message {
  id              String   @id @default(cuid())
  branchId        String
  parentMessageId String?
  role            String
  content         String
  tag               String?
  tagColor          String?
  forwardedFrom     String?
  replyToId         String?
  isCheckpoint      Boolean  @default(false)
  checkpointSummary String?
  createdAt         DateTime @default(now())
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  parent          Message? @relation("MessageTree", fields: [parentMessageId], references: [id])
  children        Message[] @relation("MessageTree")
}

model Stash {
  id            String   @id @default(cuid())
  branchId      String
  headMessageId String
  name          String
  createdAt     DateTime @default(now())
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}
